@page "/cache-demo"
@using VapeCache.Abstractions.Caching
@using System.Text
@inject ICacheService CacheService
@inject ILogger<CacheDemo> Logger
@rendermode InteractiveServer

<PageTitle>VapeCache Demo</PageTitle>

<h1>VapeCache Demo</h1>

<p>Test VapeCache operations with Enterprise features (Persistence + Reconciliation)</p>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3>Cache Operations</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="cacheKey" class="form-label">Key</label>
                    <input type="text" class="form-control" id="cacheKey" @bind="cacheKey" placeholder="Enter cache key">
                </div>

                <div class="mb-3">
                    <label for="cacheValue" class="form-label">Value</label>
                    <input type="text" class="form-control" id="cacheValue" @bind="cacheValue" placeholder="Enter cache value">
                </div>

                <div class="mb-3">
                    <label for="ttlSeconds" class="form-label">TTL (seconds)</label>
                    <input type="number" class="form-control" id="ttlSeconds" @bind="ttlSeconds" placeholder="300">
                </div>

                <div class="btn-group" role="group">
                    <button class="btn btn-primary" @onclick="SetValue" disabled="@isLoading">
                        @if (isLoading && lastOperation == "SET")
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        SET
                    </button>
                    <button class="btn btn-success" @onclick="GetValue" disabled="@isLoading">
                        @if (isLoading && lastOperation == "GET")
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        GET
                    </button>
                    <button class="btn btn-danger" @onclick="DeleteValue" disabled="@isLoading">
                        @if (isLoading && lastOperation == "DELETE")
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        DELETE
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(operationResult))
        {
            <div class="alert @alertClass mt-3" role="alert">
                <strong>@lastOperation Result:</strong> @operationResult
            </div>
        }
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h3>Recent Operations</h3>
            </div>
            <div class="card-body">
                <div class="list-group" style="max-height: 400px; overflow-y: auto;">
                    @foreach (var log in operationLogs.Take(10))
                    {
                        <div class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">@log.Operation</h6>
                                <small>@log.Timestamp.ToString("HH:mm:ss")</small>
                            </div>
                            <p class="mb-1">Key: <code>@log.Key</code></p>
                            @if (!string.IsNullOrEmpty(log.Value))
                            {
                                <small>Value: @log.Value</small>
                            }
                            <br />
                            <small class="@(log.Success ? "text-success" : "text-danger")">
                                @(log.Success ? "✓ Success" : "✗ Failed") - @log.Duration.TotalMilliseconds ms
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3>Performance Test</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <label for="numOperations" class="form-label">Number of Operations</label>
                        <input type="number" class="form-control" id="numOperations" @bind="numOperations" min="10" max="10000" value="100">
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-info mt-4" @onclick="RunBenchmark" disabled="@isBenchmarking">
                            @if (isBenchmarking)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <text>Running...</text>
                            }
                            else
                            {
                                <text>Run Benchmark</text>
                            }
                        </button>
                    </div>
                </div>

                @if (benchmarkResult != null)
                {
                    <div class="mt-3">
                        <h5>Benchmark Results:</h5>
                        <ul>
                            <li><strong>Operations:</strong> @benchmarkResult.TotalOperations</li>
                            <li><strong>Duration:</strong> @benchmarkResult.TotalDuration.TotalMilliseconds ms</li>
                            <li><strong>Throughput:</strong> @((int)(benchmarkResult.TotalOperations / benchmarkResult.TotalDuration.TotalSeconds)) ops/sec</li>
                            <li><strong>Avg Latency:</strong> @(benchmarkResult.TotalDuration.TotalMilliseconds / benchmarkResult.TotalOperations) ms/op</li>
                            <li><strong>Success Rate:</strong> @((benchmarkResult.Successes * 100.0 / benchmarkResult.TotalOperations).ToString("F2"))%</li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string cacheKey = "test:key";
    private string cacheValue = "Hello, VapeCache!";
    private int ttlSeconds = 300;
    private bool isLoading = false;
    private bool isBenchmarking = false;
    private string? operationResult;
    private string alertClass = "alert-info";
    private string lastOperation = "";
    private int numOperations = 100;

    private List<OperationLog> operationLogs = new();
    private BenchmarkResult? benchmarkResult;

    private async Task SetValue()
    {
        isLoading = true;
        lastOperation = "SET";
        var startTime = DateTime.UtcNow;

        try
        {
            var valueBytes = Encoding.UTF8.GetBytes(cacheValue);
            var ttl = ttlSeconds > 0 ? TimeSpan.FromSeconds(ttlSeconds) : (TimeSpan?)null;

            await CacheService.SetAsync(cacheKey, valueBytes, ttl);

            operationResult = $"Successfully set key '{cacheKey}' with TTL {ttlSeconds}s";
            alertClass = "alert-success";

            operationLogs.Insert(0, new OperationLog
                {
                    Operation = "SET",
                    Key = cacheKey,
                    Value = cacheValue,
                    Success = true,
                    Duration = DateTime.UtcNow - startTime,
                    Timestamp = DateTime.UtcNow
                });
        }
        catch (Exception ex)
        {
            operationResult = $"Error: {ex.Message}";
            alertClass = "alert-danger";
            Logger.LogError(ex, "Failed to SET cache key {Key}", cacheKey);

            operationLogs.Insert(0, new OperationLog
                {
                    Operation = "SET",
                    Key = cacheKey,
                    Value = ex.Message,
                    Success = false,
                    Duration = DateTime.UtcNow - startTime,
                    Timestamp = DateTime.UtcNow
                });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GetValue()
    {
        isLoading = true;
        lastOperation = "GET";
        var startTime = DateTime.UtcNow;

        try
        {
            var result = await CacheService.GetAsync(cacheKey);

            if (result.IsSuccess && result.Value != null)
            {
                var value = Encoding.UTF8.GetString(result.Value.Span);
                operationResult = $"Found: '{value}'";
                alertClass = "alert-success";
                cacheValue = value;

                operationLogs.Insert(0, new OperationLog
                    {
                        Operation = "GET",
                        Key = cacheKey,
                        Value = value,
                        Success = true,
                        Duration = DateTime.UtcNow - startTime,
                        Timestamp = DateTime.UtcNow
                    });
            }
            else
            {
                operationResult = "Key not found";
                alertClass = "alert-warning";

                operationLogs.Insert(0, new OperationLog
                    {
                        Operation = "GET",
                        Key = cacheKey,
                        Value = "Not found",
                        Success = false,
                        Duration = DateTime.UtcNow - startTime,
                        Timestamp = DateTime.UtcNow
                    });
            }
        }
        catch (Exception ex)
        {
            operationResult = $"Error: {ex.Message}";
            alertClass = "alert-danger";
            Logger.LogError(ex, "Failed to GET cache key {Key}", cacheKey);

            operationLogs.Insert(0, new OperationLog
                {
                    Operation = "GET",
                    Key = cacheKey,
                    Value = ex.Message,
                    Success = false,
                    Duration = DateTime.UtcNow - startTime,
                    Timestamp = DateTime.UtcNow
                });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteValue()
    {
        isLoading = true;
        lastOperation = "DELETE";
        var startTime = DateTime.UtcNow;

        try
        {
            await CacheService.DeleteAsync(cacheKey);

            operationResult = $"Successfully deleted key '{cacheKey}'";
            alertClass = "alert-success";

            operationLogs.Insert(0, new OperationLog
                {
                    Operation = "DELETE",
                    Key = cacheKey,
                    Success = true,
                    Duration = DateTime.UtcNow - startTime,
                    Timestamp = DateTime.UtcNow
                });
        }
        catch (Exception ex)
        {
            operationResult = $"Error: {ex.Message}";
            alertClass = "alert-danger";
            Logger.LogError(ex, "Failed to DELETE cache key {Key}", cacheKey);

            operationLogs.Insert(0, new OperationLog
                {
                    Operation = "DELETE",
                    Key = cacheKey,
                    Value = ex.Message,
                    Success = false,
                    Duration = DateTime.UtcNow - startTime,
                    Timestamp = DateTime.UtcNow
                });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RunBenchmark()
    {
        isBenchmarking = true;
        var startTime = DateTime.UtcNow;
        int successes = 0;

        try
        {
            for (int i = 0; i < numOperations; i++)
            {
                try
                {
                    var key = $"benchmark:key:{i}";
                    var value = Encoding.UTF8.GetBytes($"value-{i}");

                    // SET operation
                    await CacheService.SetAsync(key, value, TimeSpan.FromMinutes(1));

                    // GET operation
                    var result = await CacheService.GetAsync(key);

                    if (result.IsSuccess)
                    {
                        successes++;
                    }

                    // DELETE operation
                    await CacheService.DeleteAsync(key);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Benchmark operation {Index} failed", i);
                }
            }

            var duration = DateTime.UtcNow - startTime;

            benchmarkResult = new BenchmarkResult
                {
                    TotalOperations = numOperations * 3, // SET + GET + DELETE
                    TotalDuration = duration,
                    Successes = successes
                };

            operationResult = $"Benchmark completed: {numOperations * 3} operations in {duration.TotalMilliseconds:F2}ms";
            alertClass = "alert-success";
        }
        catch (Exception ex)
        {
            operationResult = $"Benchmark error: {ex.Message}";
            alertClass = "alert-danger";
            Logger.LogError(ex, "Benchmark failed");
        }
        finally
        {
            isBenchmarking = false;
        }
    }

    private class OperationLog
    {
        public string Operation { get; set; } = "";
        public string Key { get; set; } = "";
        public string? Value { get; set; }
        public bool Success { get; set; }
        public TimeSpan Duration { get; set; }
        public DateTime Timestamp { get; set; }
    }

    private class BenchmarkResult
    {
        public int TotalOperations { get; set; }
        public TimeSpan TotalDuration { get; set; }
        public int Successes { get; set; }
    }
}
