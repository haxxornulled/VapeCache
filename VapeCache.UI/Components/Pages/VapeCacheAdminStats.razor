@page "/vapecache/stats"
@attribute [Authorize(Policy = VapeCacheAdminPageDefaults.AuthorizationPolicyName)]

<PageTitle>VapeCache Stats</PageTitle>

<section class="vc-admin-shell">
    <header class="vc-admin-header">
        <div>
            <h1>Cache Stats</h1>
            <p>Cumulative read/write throughput and cache outcome counters from the live shared snapshot.</p>
        </div>
        <button class="vc-button" @onclick="RefreshAsync">Refresh</button>
    </header>

    <VapeCacheAdminNav />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="vc-error">@_error</p>
    }

    <section class="vc-admin-grid vc-admin-grid-4">
        <article class="vc-card">
            <h2>Cumulative Reads</h2>
            <p class="vc-kpi">@_snapshot.Reads</p>
        </article>
        <article class="vc-card">
            <h2>Cumulative Writes</h2>
            <p class="vc-kpi">@_snapshot.Writes</p>
        </article>
        <article class="vc-card">
            <h2>Current Hit Rate</h2>
            <p class="vc-kpi">@((_snapshot.HitRate * 100d).ToString("F2"))%</p>
        </article>
        <article class="vc-card">
            <h2>Cumulative Fallback Events</h2>
            <p class="vc-kpi">@_snapshot.Stats.FallbackToMemory</p>
        </article>
    </section>

    <article class="vc-card">
        <h2>Cumulative Counter Detail</h2>
        <dl class="vc-dl">
            <dt>Total Get Calls</dt><dd>@_snapshot.Stats.GetCalls</dd>
            <dt>Total Set Calls</dt><dd>@_snapshot.Stats.SetCalls</dd>
            <dt>Total Remove Calls</dt><dd>@_snapshot.Stats.RemoveCalls</dd>
            <dt>Total Hits</dt><dd>@_snapshot.Stats.Hits</dd>
            <dt>Total Misses</dt><dd>@_snapshot.Stats.Misses</dd>
            <dt>Total Breaker Opens</dt><dd>@_snapshot.Stats.RedisBreakerOpened</dd>
            <dt>Total Stampede Key Rejects</dt><dd>@_snapshot.Stats.StampedeKeyRejected</dd>
            <dt>Total Stampede Lock Waits</dt><dd>@_snapshot.Stats.StampedeLockWaitTimeout</dd>
            <dt>Total Stampede Backoff Rejects</dt><dd>@_snapshot.Stats.StampedeFailureBackoffRejected</dd>
        </dl>
    </article>
</section>
