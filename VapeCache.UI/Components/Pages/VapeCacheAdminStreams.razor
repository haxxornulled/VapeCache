@page "/vapecache/streams"
@attribute [Authorize(Policy = VapeCacheAdminPageDefaults.AuthorizationPolicyName)]

<PageTitle>VapeCache Streams</PageTitle>

<section class="vc-admin-shell">
    <header class="vc-admin-header">
        <div>
            <h1>Streams and Events</h1>
            <p>Live stream and shared snapshot surface for operational diagnostics.</p>
        </div>
        <button class="vc-button" @onclick="RefreshAsync">Refresh</button>
    </header>

    <VapeCacheAdminNav />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="vc-error">@_error</p>
    }

    <section class="vc-admin-grid vc-admin-grid-3">
        <article class="vc-card">
            <h2>Feed Registered</h2>
            <p class="vc-kpi">@_status.FeedRegistered</p>
            <p class="vc-meta">runtime live-feed service availability</p>
        </article>
        <article class="vc-card">
            <h2>Stream Endpoint</h2>
            <p class="vc-kpi">@_status.StreamEndpointEnabled</p>
            <p class="vc-meta">endpoint policy gate</p>
        </article>
        <article class="vc-card">
            <h2>Intent Endpoint</h2>
            <p class="vc-kpi">@_status.IntentEndpointEnabled</p>
            <p class="vc-meta">endpoint policy gate</p>
        </article>
    </section>

    <article class="vc-card">
        <h2>Endpoint Views</h2>
        <ul class="vc-list">
            <li><a href="@_status.StreamEndpointPath" target="_blank">Live Stream Endpoint</a></li>
            <li><a href="@_status.SharedSnapshotEndpointPath" target="_blank">Shared Snapshot Endpoint</a></li>
            <li><a href="@_status.IntentEndpointPath" target="_blank">Recent Intent Endpoint</a></li>
        </ul>
        <p class="vc-meta">
            Stream and intent endpoints are development-enabled by default and can be explicitly enabled outside development.
        </p>
    </article>
</section>

