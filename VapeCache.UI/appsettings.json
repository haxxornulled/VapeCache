{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RedisConnection": {
    "Host": "192.168.100.50",
    "Port": 6379
  },
  "RedisMultiplexer": {
    "Connections": 64,
    "EnableAutoscaling": true,
    "MinConnections": 16,
    "MaxConnections": 64,
    "BulkLaneConnections": 16,
    "AutoAdjustBulkLanes": true,
    "BulkLaneTargetRatio": 0.25
  },
  "VapeCache": {
    "Endpoints": {
      "EnableBreakerControl": false
    },
    "RedisExporter": {
      "Enabled": false,
      "Endpoint": "http://localhost:9121/metrics",
      "PollInterval": "00:00:05",
      "RequestTimeout": "00:00:02"
    }
  },
  "AllowedHosts": "*"
}
