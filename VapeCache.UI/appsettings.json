{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RedisConnection": {
    "ConnectionString": null,
    "Host": "127.0.0.1",
    "Port": 6379,
    "Username": null,
    "Password": null
  },
  "RedisMultiplexer": {
    "Connections": 64,
    "EnableAutoscaling": true,
    "MinConnections": 16,
    "MaxConnections": 64,
    "BulkLaneConnections": 16,
    "AutoAdjustBulkLanes": true,
    "BulkLaneTargetRatio": 0.25
  },
  "VapeCache": {
    "Endpoints": {
      "EnableBreakerControl": false,
      "EnableIntentEndpoints": false,
      "EnableLiveStream": false,
      "RequireAdminAuthorizationInDevelopment": false
    },
    "RedisExporter": {
      "Enabled": false,
      "Endpoint": "http://localhost:9121/metrics",
      "PollInterval": "00:00:05",
      "RequestTimeout": "00:00:02"
    }
  },
  "Authentication": {
    "JwtBearer": {
      "Enabled": false,
      "Authority": "",
      "Audience": "",
      "RequireHttpsMetadata": true,
      "SigningKey": "",
      "ValidIssuer": "",
      "ValidAudience": ""
    }
  },
  "AllowedHosts": "*"
}
