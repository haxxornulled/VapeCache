<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsPackable>true</IsPackable>
    <PackageId>VapeCache</PackageId>
    <Version>1.0.1</Version>
    <Authors>VapeCache Contributors</Authors>
    <Company>VapeCache</Company>
    <Product>VapeCache</Product>
    <Description>VapeCache - High-performance Redis client for .NET optimized for caching workloads. Features coalesced writes (29% faster SETs), zero-allocation pooling, circuit breaker failover, and OpenTelemetry observability. 5-30% faster than StackExchange.Redis.</Description>
    <PackageTags>redis;cache;performance;distributed-cache;async;netcore;hybrid-cache;circuit-breaker;opentelemetry</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/haxxornulled/VapeCache</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/haxxornulled/VapeCache</PackageProjectUrl>
    <Copyright>Copyright (c) 2025 VapeCache Contributors</Copyright>
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\nupkg</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="VapeCache.Tests" />
    <InternalsVisibleTo Include="VapeCache.Benchmarks" />
    <InternalsVisibleTo Include="VapeCache.Benchmarks.Runner" />
    <InternalsVisibleTo Include="VapeCache.PerfGates.Tests" />
    <InternalsVisibleTo Include="VapeCache.Reconciliation" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Autofac" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="10.0.1" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.1" />
    <PackageReference Include="Polly" Version="8.6.5" />
    <!--
      REMOVED: Serilog sink dependencies (Console, File)
      VapeCache.Infrastructure is a library and should only use ILogger<T> abstraction.
      Consumers choose their logging implementation (Serilog, NLog, etc.) in their host project.
      SEQ/console/file sinks belong in VapeCache.Console or user's host project.
    -->
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\VapeCache.Abstractions\VapeCache.Abstractions.csproj" />
  </ItemGroup>

</Project>
